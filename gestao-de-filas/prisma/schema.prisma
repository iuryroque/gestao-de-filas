// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "sqlite"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    role          String    @default("attendant") // attendant | supervisor | admin
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
    tickets       Ticket[]
    ticketLogs    TicketLog[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// Domain models for queue management
model Queue {
    id        String   @id @default(cuid())
    name      String   @unique
    isActive  Boolean  @default(true)
    tma       Int      @default(5)  // average service time in minutes
    sla       Int      @default(30) // SLA limit in minutes (default 30 min)
    createdAt DateTime @default(now())
    tickets      Ticket[]
    desks        Desk[]
    slaBreaches  SlaBreachLog[]

    @@index([name])
}

/// Attendant desk (guichê)
model Desk {
    id          String   @id @default(cuid())
    name        String   @unique
    status      String   @default("closed") // active | paused | closed
    pauseReason String?
    queueId     String?  // null = serves all queues
    createdAt   DateTime @default(now())

    queue      Queue?         @relation(fields: [queueId], references: [id])
    tickets    Ticket[]
    stateLogs  DeskStateLog[]

    @@index([status])
}

/// Audit log for supervisor desk state changes (US-10)
model DeskStateLog {
    id        String   @id @default(cuid())
    deskId    String
    state     String   // active | paused | closed
    reason    String?  // justification for state change
    actorRole String?  // supervisor | admin | system
    queueId   String?  // target queue when action is queue assignment
    createdAt DateTime @default(now())

    desk Desk @relation(fields: [deskId], references: [id], onDelete: Cascade)

    @@index([deskId])
    @@index([createdAt])
}

model Ticket {
    id                String    @id @default(cuid())
    code              String    @default("") // display code: "P-0042" (priority) or "0042" (regular)
    number            Int
    queueId           String
    deskId            String?
    userId            String?
    status            String    @default("waiting") // waiting | calling | awaiting_recall | done | no_show | transferred
    isPriority        Boolean   @default(false)
    priority          Int       @default(0)
    service           String?
    noShowCount       Int       @default(0)
    tma               Int?      // Tempo de Atendimento em segundos (calledAt → finishedAt)
    transferredFromId String?   // ID do ticket original (quando este ticket foi gerado por transferência)
    transferredToId   String?   // ID do ticket gerado na fila destino (quando este ticket foi transferido)
    transferCount     Int       @default(0) // Número de transferências já realizadas (máx 2)
    createdAt         DateTime  @default(now())
    calledAt          DateTime?
    finishedAt        DateTime?

    queue Queue      @relation(fields: [queueId], references: [id])
    desk  Desk?      @relation(fields: [deskId], references: [id])
    user  User?      @relation(fields: [userId], references: [id])
    logs  TicketLog[]
    smsMessages SmsMessage[]

    @@index([queueId, number])
    @@index([queueId, isPriority, status])
    @@index([deskId, status])
}

/// Audit log for attendant / supervisor actions on a ticket
model TicketLog {
    id        String   @id @default(cuid())
    ticketId  String
    action    String   // called | recalled | finished | no_show | reintegrated
    actorId   String?  // User.id of the attendant or supervisor
    note      String?  // optional note (e.g. reintegration reason)
    createdAt DateTime @default(now())

    ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
    actor  User?  @relation(fields: [actorId], references: [id])

    @@index([ticketId])
    @@index([actorId])
}

/// Persisted record of a SLA breach event (TME >= sla limit)
model SlaBreachLog {
    id         String   @id @default(cuid())
    queueId    String
    tmeMinutes Float    // TME (min) at the moment of breach
    slaLimit   Int      // configured SLA limit for the queue at breach time
    createdAt  DateTime @default(now())

    queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)

    @@index([queueId])
    @@index([createdAt])
}

/// SMS messages queued/sent by the system (US-02 sandbox)
model SmsMessage {
    id        String   @id @default(cuid())
    ticketId  String
    phone     String
    provider  String?  // e.g. twilio, mock
    status    String   @default("queued") // queued | sent | failed
    createdAt DateTime @default(now())

    ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

    @@index([ticketId])
}
