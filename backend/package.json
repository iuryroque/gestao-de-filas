{
  "name": "gestao-filas-backend",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand",
    "migrate:up": "node-pg-migrate up -m backend/migrations",
    "migrate:down": "node-pg-migrate down -m backend/migrations",
    "start:dev:pg": "cross-env DB_CLIENT=pg node src/index.js"
  },
  "jest": {
    "setupFiles": ["./test/jest.setup.js"]
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "pg": "^8.10.0",
    "node-pg-migrate": "^7.4.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "nodemon": "^2.0.22",
    "supertest": "^6.3.3",
    "cross-env": "^7.0.3"
  }
}
